{
  "name": "@xifu/check-text-color",
  "version": "1.0.0",
  "description": "评估页面上每个文字DOM渲染时的可见性（视觉层面），基于html2canvas像素分析和WCAG对比度算法",
  "type": "module",
  "main": "./dist/check-text-color.umd.cjs",
  "module": "./dist/check-text-color.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/check-text-color.js",
      "require": "./dist/check-text-color.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "text-visibility",
    "contrast",
    "wcag",
    "a11y",
    "accessibility"
  ],
  "license": "MIT",
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite": "^5.4.2",
    "vite-plugin-dts": "^3.9.1"
  }
}
